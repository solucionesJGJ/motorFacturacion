{
  "name": "terminal",
  "version": "1.0.0",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "npm run build && node --test test/*.test.mjs",
    "test:integration": "npm run build && node --test test/*.integration.mjs",
    "dev": "tsx watch src/app.ts",
    "worker": "tsx watch src/workers/file-watcher.worker.ts",
    "job-worker": "tsx watch src/workers/billing-job.worker.ts",
    "dev:all": "concurrently \"npm run dev\" \"npm run worker\" \"npm run job-worker\"",
    "start": "node dist/app.js",
    "build": "tsc",
    "db:sync": "tsx src/database/sync.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "chokidar": "^5.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "fast-xml-parser": "^5.8.0",
    "pg": "^8.22.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.8",
    "xmlbuilder2": "^4.0.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.3",
    "concurrently": "^10.0.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}